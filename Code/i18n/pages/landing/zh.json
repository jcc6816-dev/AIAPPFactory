  "faq": {
    "name": "faq",
    "label": "常见问题",
    "title": "关于 AI FormFactory 的常见问题",
    "description": "首页先回答模板、生成、发布和集成相关问题。",
    "items": [
      {
        "title": "这是一套什么样的产品？",
        "description": "当前阶段它是一套 AI 表单生成与数据收集系统，重点是用模板和 Agent 帮用户快速生成可发布场景。"
      },
      {
        "title": "为什么需要模板？",
        "description": "模板能让用户直接看到可用场景，不必从空白页学习。用户先选择一个接近业务的模板，再用 AI 修改，会更容易上手。"
      },
      {
        "title": "它和普通表单工具有什么不同？",
        "description": "普通表单工具更偏手动搭建；AI FormFactory 的目标是从模板或一句话生成，并在页面 Agent 帮助下持续调整、发布和分析。"
      },
      {
        "title": "当前是否已经支持真实提交？",
        "description": "支持。用户可以生成表单、保存场景、分享填写页、收集提交数据，并配置 Webhook 推送。"
      },
      {
        "title": "Agent 当前做什么？",
        "description": "当前 Agent 主要围绕页面上下文做辅助：生成表单、修改字段、总结提交、分析数据和帮助配置发布。"
      },
      {
        "title": "下一步会扩展什么？",
        "description": "优先深化模板体系、生成体验、真实 Agent 工具调用、OCR 和工作流，但会继续围绕用户能感知的实际价值推进。"
      }
    ]
  },
